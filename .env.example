# ──────────────────────────────────────────────
# SPREAD FINANCE — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# Ne JAMAIS committer .env.local sur Git
# ──────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────
# Dashboard : https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── SANITY CMS ────────────────────────────────
# Dashboard : https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=your-read-token

# ── STRIPE ────────────────────────────────────
# Dashboard : https://dashboard.stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs — créer dans Stripe Dashboard
STRIPE_PREMIUM_PRICE_ID=price_...

# ── RESEND (emails) ───────────────────────────
# Dashboard : https://resend.com/dashboard
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@spreadfinance.fr

# ── APP ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
